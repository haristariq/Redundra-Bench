+from redundra_utils.text import truncate
+
+
+def test_truncate_whole_words_trims_to_boundary():
+    assert truncate('hello world foo', 10, whole_words=True) == 'hello\u2026'
+
+
+def test_truncate_whole_words_default_still_cuts():
+    assert truncate('hello world foo', 10) == 'hello wor\u2026'
+
+
+def test_truncate_whole_words_no_truncation_needed():
+    assert truncate('hi there', 20, whole_words=True) == 'hi there'
