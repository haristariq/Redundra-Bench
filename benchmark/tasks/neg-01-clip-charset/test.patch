+from redundra_utils.sanitize import clip_to_charset
+
+
+def test_clip_to_charset_filters():
+    assert clip_to_charset('a1b2c3', 'abc') == 'abc'
+
+
+def test_clip_to_charset_preserves_order_and_dupes():
+    assert clip_to_charset('hello!', 'helo') == 'hello'
+
+
+def test_clip_to_charset_empty_allowed():
+    assert clip_to_charset('abc', '') == ''
