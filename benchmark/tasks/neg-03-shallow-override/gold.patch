@@ -0,0 +1,12 @@
+"""Flat config override."""
+
+from __future__ import annotations
+
+from typing import Any, Mapping
+
+__all__ = ["shallow_override"]
+
+
+def shallow_override(base: Mapping[str, Any], override: Mapping[str, Any]) -> dict:
+    """Return ``base`` with top-level keys replaced by ``override`` (no recursion)."""
+    return {**base, **override}
