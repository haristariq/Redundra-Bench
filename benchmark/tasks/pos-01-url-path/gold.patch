+"""Web helpers."""
+
+from __future__ import annotations
+
+from .text import slugify
+
+__all__ = ["make_url_path"]
+
+
+def make_url_path(title: str) -> str:
+    """Return ``title`` as a URL path (e.g. ``/hello-world``)."""
