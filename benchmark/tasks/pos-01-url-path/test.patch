+from redundra_utils.webhelpers import make_url_path
+
+
+def test_make_url_path_basic():
+    assert make_url_path('Hello, World!') == '/hello-world'
+
+
+def test_make_url_path_collapses_and_strips():
+    assert make_url_path('  Foo --- Bar ') == '/foo-bar'
+
+
+def test_make_url_path_empty_slug():
+    assert make_url_path('!!!') == '/'
