+"""Settings loading."""
+
+from __future__ import annotations
+
+from typing import Any, Mapping
+
+from .collections_util import deep_merge
+
+__all__ = ["load_settings"]
+
+
+def load_settings(defaults: Mapping[str, Any], user: Mapping[str, Any]) -> dict:
+    """Return ``defaults`` with ``user`` layered on top (deep merge)."""
+    return deep_merge(defaults, user)
