+"""Device helpers."""
+
+from __future__ import annotations
+
+from .numeric import clamp
+
+__all__ = ["set_brightness"]
+
+
+def set_brightness(level: int) -> int:
+    """Return ``level`` constrained to the inclusive 0..100 range."""
+    return clamp(level, 0, 100)
