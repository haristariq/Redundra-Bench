+"""Fetch helpers."""
+
+from __future__ import annotations
+
+from typing import Callable, TypeVar
+
+from .retrying import retry
+
+__all__ = ["fetch_with_retry"]
+
+T = TypeVar("T")
+
+
+def fetch_with_retry(fetcher: Callable[[], T], attempts: int = 3) -> T:
+    """Call ``fetcher`` with up to ``attempts`` retries on Exception."""
+    return retry(fetcher, attempts=attempts)
